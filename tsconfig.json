{
  "compilerOptions": {
    "allowJs": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "target": "es6"
  },
  "include": [
    "src/**/*.ts",
    "node_modules/document/**/*.ts"
  ],
  "exclude": [
    "node_modules/document/**/*.spec.ts"
  ],
  "ts-node": {
    "ignore": []
  }
}
